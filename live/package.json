{
  "name": "3-guys-landing",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 127.0.0.1 --port 3000",
    "dev:api": "NODE_ENV=development node server.mjs",
